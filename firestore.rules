rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'bernard30101994@gmail.com' ||
        request.auth.token.email == 'supervisao@vonixx.com'
      );
    }

    function getUserShift() {
      let email = request.auth.token.email;
      return (email == 'turnoa@vonixx.com' || email == 'turno.a@vonixx.com') ? 'A' :
             (email == 'turnob@vonixx.com' || email == 'turno.b@vonixx.com') ? 'B' :
             (email == 'turnoc@vonixx.com' || email == 'turno.c@vonixx.com') ? 'C' :
             (email == 'turnod@vonixx.com' || email == 'turno.d@vonixx.com') ? 'D' : null;
    }

    function isOwnerShift() {
      let shift = getUserShift();
      return isAdmin() || (shift != null && (
        !('shift' in resource.data) ||
        resource.data.shift == shift
      ));
    }

    function isCreatingOwnShift() {
      return isAdmin() ||
             !('shift' in request.resource.data) ||
             request.resource.data.shift == getUserShift();
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    function isValidEmployee() {
      return hasRequiredFields(['name']) &&
             isValidString('name', 1, 100) &&
             (!('createdAt' in request.resource.data) ||
               request.resource.data.createdAt is timestamp ||
               request.resource.data.createdAt is string) &&
             (!('shift' in request.resource.data) ||
               request.resource.data.shift in ['A', 'B', 'C', 'D']);
    }

    function isValidVacation() {
      return hasRequiredFields(['employeeId', 'startDate', 'endDate', 'status']) &&
             isValidString('employeeId', 1, 100) &&
             isValidString('startDate', 1, 20) &&
             isValidString('endDate', 1, 20) &&
             request.resource.data.status in ['scheduled', 'taken', 'cancelled'] &&
             (!('updatedAt' in request.resource.data) ||
               request.resource.data.updatedAt is timestamp) &&
             (!('shift' in request.resource.data) ||
               request.resource.data.shift in ['A', 'B', 'C', 'D']);
    }

    function isValidAttendanceRecord() {
      return hasOnlyAllowedFields(['empId', 'day', 'month', 'year', 'status', 'note', 'updatedAt', 'shift', 'markedAt', 'markedViaKiosk']) &&
             hasRequiredFields(['empId', 'day', 'month', 'year', 'status', 'shift']) &&
             isValidString('empId', 1, 50) &&
             request.resource.data.day is number &&
             request.resource.data.day >= 1 &&
             request.resource.data.day <= 31 &&
             request.resource.data.month is number &&
             request.resource.data.month >= 0 &&
             request.resource.data.month <= 11 &&
             request.resource.data.year is number &&
             request.resource.data.year >= 2024 &&
             request.resource.data.year <= 2030 &&
             request.resource.data.status in ['P', 'F', 'Fe', 'A'] &&
             isValidOptionalString('note', 0, 500) &&
             request.resource.data.shift in ['A', 'B', 'C', 'D'];
    }

    // ─── config/passwords ────────────────────────────────────────────────────
    match /config/passwords {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── config/accessCode: kiosk QR ─────────────────────────────────────────
    // Leitura pública (kiosk não está logado).
    // Escrita permitida para qualquer autenticado: o código é temporário (30s),
    // não contém dados sensíveis e qualquer turno logado pode rotacioná-lo.
    match /config/accessCode {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /employees/{employeeId} {
      allow read: if isAuthenticated() && isOwnerShift();
      allow create: if isAuthenticated() && isValidEmployee() && isCreatingOwnShift();
      allow update: if isAuthenticated() && isValidEmployee() && isOwnerShift() && isCreatingOwnShift() &&
                       (!('createdAt' in resource.data) ||
                         request.resource.data.createdAt == resource.data.createdAt);
      allow delete: if isAuthenticated() && isOwnerShift();
    }

    match /vacations/{vacationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidVacation();
      allow update: if isAuthenticated() && isValidVacation();
      allow delete: if isAuthenticated();
    }

    match /attendance/{recordId} {
      allow read: if isAuthenticated() && isOwnerShift();
      allow create: if isValidAttendanceRecord() && isCreatingOwnShift();
      allow update: if isValidAttendanceRecord() && isOwnerShift() && isCreatingOwnShift();
      allow delete: if isAuthenticated() && isOwnerShift();
    }

    match /completions/{completionId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() &&
                    hasRequiredFields(['shift', 'day', 'month', 'year', 'completedAt', 'completedBy']) &&
                    request.resource.data.shift in ['A', 'B', 'C', 'D'] &&
                    request.resource.data.day is number &&
                    request.resource.data.month is number &&
                    request.resource.data.year is number &&
                    request.resource.data.completedAt is timestamp &&
                    request.resource.data.completedBy == request.auth.token.email;
    }

    match /ai_insights/{insightId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /system/ai_config {
      allow read, write: if isAdmin();
    }

    match /system/{systemId} {
      allow read, write: if isAuthenticated();
    }
  }
}
